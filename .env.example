# --- API service ---
NODE_ENV=development
API_PORT=3001
DATABASE_URL=postgres://nclex:nclex@localhost:5432/nclex
REDIS_URL=redis://localhost:6379
SESSION_COOKIE_SECRET=change-me-in-prod-min-32-chars-long!!

# --- Object storage (MinIO in dev, S3 in prod) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=nclex-sources
S3_ACCESS_KEY=nclex
S3_SECRET_KEY=nclexsecret

# --- AI worker ---
WORKER_PORT=8000
ANTHROPIC_API_KEY=sk-ant-your-key-here
GENERATION_MODEL=claude-opus-4-8
CLASSIFY_MODEL=claude-haiku-4-5-20251001
EMBEDDING_DIM=1536
