# --- API service ---
NODE_ENV=development
API_PORT=3001
DATABASE_URL=postgres://nclex:nclex@localhost:5432/nclex
REDIS_URL=redis://localhost:6379
SESSION_COOKIE_SECRET=change-me-in-prod-min-32-chars-long!!

# --- Object storage (MinIO in dev, S3 in prod) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=nclex-sources
S3_ACCESS_KEY=nclex
S3_SECRET_KEY=nclexsecret

# ---------------------------------------------------------------------------
# LLM Provider - pick ONE block below and comment out the others
# ---------------------------------------------------------------------------

# --- Option 1: Google Gemini (default, free tier available) ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIza-your-gemini-key-here
GENERATION_MODEL=gemini-2.0-flash
CLASSIFY_MODEL=gemini-2.0-flash

# --- Option 2: Anthropic via OpenRouter (swap anytime, no code change) ---
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
# GENERATION_MODEL=anthropic/claude-opus-4-5
# CLASSIFY_MODEL=anthropic/claude-3-haiku

# --- Option 3: Anthropic direct ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# GENERATION_MODEL=claude-opus-4-5
# CLASSIFY_MODEL=claude-3-haiku-20240307

# --- AI worker ---
WORKER_PORT=8000
EMBEDDING_DIM=1536
